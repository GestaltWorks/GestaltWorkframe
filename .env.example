# Gestalt Workframe — example environment configuration.
# Copy to .env and fill in the values you actually need. Anything left blank
# falls back to safe defaults defined in the source. None of these belong in
# version control.

# ---------------------------------------------------------------------------
# Deployment selection
# ---------------------------------------------------------------------------
# Picks the bundle under deployments/<id>/. Ships with test-brand as a sample.
DEPLOYMENT_ID=test-brand

# Public origin of the site (used in absolute links, emails, sitemaps).
SITE_PUBLIC_URL=

# Comma-separated CORS allow-list for the FastAPI app. Leave blank in dev.
CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Admin gate
# ---------------------------------------------------------------------------
# Required to read or modify admin API state (health, discovery, newsletter).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_POLICY_TOKEN=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# SQLite file path or full SQLAlchemy URL. URL wins if both are set.
APP_DATABASE_PATH=database.db
APP_DATABASE_URL=

# Vector store directory for the local Chroma index.
CHROMA_DB_DIR=kb/chroma_db

# ---------------------------------------------------------------------------
# OpenRouter (primary model-access path)
# ---------------------------------------------------------------------------
# Single API key routes all model traffic: free-tier, low-cost, and premium
# escalation are all selected from profiles.json by the task router.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Override the OpenRouter base URL only if you are self-hosting a compatible proxy.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Cloud spend gates (apply to low_cost and premium OpenRouter routes)
# ---------------------------------------------------------------------------
# Free-tier routes (cost_tier=free) are not subject to USD caps.
# These caps only gate metered (low_cost / premium) escalation routes.
ENABLE_CLOUD_SPILLOVER=false
ENABLE_LOW_COST_CLOUD=false

# Master switch for premium (Sonnet/Opus) escalation.
ENABLE_CLAUDE_FALLBACK=false

# Routing strategy: best_value | prefer_local | prefer_cloud_quality | local_only | cloud_only
ROUTING_STRATEGY=best_value

# Global call and token caps for ALL metered cloud escalation.
CLOUD_SPILLOVER_MAX_CALLS_PER_TURN=1
CLOUD_SPILLOVER_MAX_CALLS_PER_SESSION=10
CLOUD_SPILLOVER_MAX_CALLS_PER_DAY=20
CLOUD_SPILLOVER_MAX_CALLS_PER_MONTH=500
CLOUD_SPILLOVER_MAX_DAILY_USD=10
CLOUD_SPILLOVER_MAX_MONTHLY_USD=100
CLOUD_SPILLOVER_MAX_INPUT_TOKENS_PER_CALL=16000
CLOUD_SPILLOVER_MAX_OUTPUT_TOKENS_PER_CALL=2048

# Per-provider USD caps (independent of the global cap above).
# Each provider's spend is tracked separately. Set ENABLED=true and a USD cap
# to activate. Unset or ENABLED=false means that provider uses the global cap only.
# The router blocks a route when EITHER the global cap OR the provider cap is exhausted.
OPENROUTER_BUDGET_ENABLED=false
OPENROUTER_BUDGET_MAX_DAILY_USD=5
OPENROUTER_BUDGET_MAX_MONTHLY_USD=50

ANTHROPIC_BUDGET_ENABLED=false
ANTHROPIC_BUDGET_MAX_DAILY_USD=2
ANTHROPIC_BUDGET_MAX_MONTHLY_USD=20

GOOGLE_BUDGET_ENABLED=false
GOOGLE_BUDGET_MAX_DAILY_USD=1
GOOGLE_BUDGET_MAX_MONTHLY_USD=10

OPENAI_BUDGET_ENABLED=false
OPENAI_BUDGET_MAX_DAILY_USD=1
OPENAI_BUDGET_MAX_MONTHLY_USD=10

# ---------------------------------------------------------------------------
# Bolt-on: direct Anthropic SDK (disabled by default)
# ---------------------------------------------------------------------------
# Set ANTHROPIC_API_KEY and flip deployment_status on the claude-* profiles
# in llm/profiles.json if you want direct Anthropic SDK routing instead of
# going through OpenRouter for Claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_PROFILE=

# ---------------------------------------------------------------------------
# Bolt-on: local GPU inference (disabled by default)
# ---------------------------------------------------------------------------
# Set LOCAL_LLM_BASE_URL and flip deployment_status on the llama-*/qwen-*
# profiles in llm/profiles.json if an operator is bringing their own GPU host.
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=local-model
LOCAL_LLM_PROVIDER=llama_cpp
LOCAL_LLM_PROFILE=

# Ollama (alternative local runtime)
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Bolt-on: Gemini direct (disabled by default)
# ---------------------------------------------------------------------------
# Set GEMINI_CLOUD_* and flip deployment_status on gemini-cloud in profiles.json.
GEMINI_CLOUD_API_KEY=
GEMINI_CLOUD_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_CLOUD_MODEL=

# ---------------------------------------------------------------------------
# Public-traffic abuse limits
# ---------------------------------------------------------------------------
CHAT_IP_LIMIT=30
CHAT_IP_WINDOW_SECONDS=3600
CHAT_SESSION_LIMIT=12
CHAT_SESSION_WINDOW_SECONDS=3600
CHAT_DAILY_TOKEN_LIMIT=100000
CHAT_MAX_BODY_BYTES=32768
CHAT_MAX_MESSAGE_CHARS=4000
INTAKE_IP_LIMIT=20
INTAKE_SESSION_LIMIT=3
INTAKE_MAX_BODY_BYTES=32768
CONTACT_MAX_BODY_BYTES=65536

# ---------------------------------------------------------------------------
# Discovery (optional — content ingestion pipeline)
# ---------------------------------------------------------------------------
APP_GITHUB_TOKEN=
BRAVE_SEARCH_API_KEY=
DISCOVERY_DIGEST_ENABLED=0
DISCOVERY_DIGEST_TO=
DISCOVERY_SCOUT_ENABLED=0
DISCOVERY_SCOUT_MAX_CALLS_PER_DAY=1
DISCOVERY_SCOUT_MAX_DAILY_USD=1.00

# ---------------------------------------------------------------------------
# Library publisher (optional — pushes approved sources to a public corpus repo)
# ---------------------------------------------------------------------------
LIBRARY_PUBLISHER_REPO=
LIBRARY_PUBLISHER_BASE_BRANCH=main
LIBRARY_PUBLISHER_GITHUB_APP_ID=
LIBRARY_PUBLISHER_GITHUB_INSTALLATION_ID=
LIBRARY_PUBLISHER_GITHUB_PRIVATE_KEY_B64=

# ---------------------------------------------------------------------------
# Microsoft 365 outbound email (optional)
# ---------------------------------------------------------------------------
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_SEND_AS=
NEWSLETTER_APPROVAL_TO=
AUTOREPLY_SENDER=

# ---------------------------------------------------------------------------
# LinkedIn newsletter publishing (optional)
# ---------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_AUTHOR_URN=

# ---------------------------------------------------------------------------
# Deployment-specific links (override the bundle's defaults)
# ---------------------------------------------------------------------------
SERVICE_INQUIRY_URL=
SERVICE_INQUIRY_EMAIL=
BOOKING_URL=
COMMUNITY_INVITE_URL=
